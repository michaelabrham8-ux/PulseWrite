{
    "manifest_version": 3,
    "name": "PulseWrite – LinkedIn Ghostwriter",
    "version": "0.1.0",
    "description": "LinkedIn post idea generator & ghostwriter powered by AI.",
    "permissions": [
        "storage",
        "activeTab",
        "scripting"
    ],
    "host_permissions": [
        "https://www.linkedin.com/*",
        "https://api.groq.com/*"
    ],
    "action": {
        "default_popup": "src/popup/index.html",
        "default_icon": {
            "16": "public/icon16.png",
            "48": "public/icon48.png",
            "128": "public/icon128.png"
        }
    },
    "icons": {
        "16": "public/icon16.png",
        "48": "public/icon48.png",
        "128": "public/icon128.png"
    },
    "content_scripts": [
        {
            "matches": [
                "https://www.linkedin.com/*"
            ],
            "js": [
                "src/content/content.ts"
            ]
        }
    ],
    "background": {
        "service_worker": "src/background/background.ts",
        "type": "module"
    }
}